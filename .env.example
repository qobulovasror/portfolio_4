# Telegram Bot for the contact form
#
# 1. Talk to @BotFather on Telegram → /newbot → copy the token here
# 2. Start a chat with your bot, send /start
# 3. Get your chat_id from: https://api.telegram.org/bot<TOKEN>/getUpdates
#    (look for "chat":{"id":...})
#
# Note: the token is exposed in the client bundle. Restrict the bot to
# sendMessage only and use a dedicated bot just for this form.
VITE_TELEGRAM_BOT_TOKEN=your_bot_token_here
VITE_TELEGRAM_CHAT_ID=your_chat_id_here
